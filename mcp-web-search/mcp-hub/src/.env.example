# SearXNG — Docker DNS name of sibling container
SEARXNG_URL=http://searxng_engine_secure:8080
SEARXNG_TIMEOUT=10
SEARXNG_HOST_HEADER=localhost
# DDGS
DDGS_TIMEOUT=10
# [anti-ban] Outbound proxy to rotate egress IP when DDGS rate-limits/bans (optional).
# e.g. socks5://user:pass@host:1080  or  http://host:3128
DDGS_PROXY=
# Rate limiting
DDGS_RATE_LIMIT=6
DDGS_BURST=3
DDGS_COOL_DOWN=300
SEARXNG_RATE_LIMIT=12
SEARXNG_BURST=6
SEARXNG_COOL_DOWN=120
# [B1b] Min image hits to treat an image answer as strong (else SearXNG failover, uncached)
IMAGE_MIN_OK=3
# Server
HOST=0.0.0.0
PORT=8765
# Cache risultati ricerche (in-memory TTL+LRU)
CACHE_ENABLED=true
CACHE_MAX_SIZE=512
CACHE_TTL_WEB=900
CACHE_TTL_NEWS=300
CACHE_TTL_IMAGE=3600
CACHE_TTL_EXTRACT=3600
# Persistenza cache su SQLite (volume)
CACHE_PERSISTENT=true
CACHE_DB_PATH=/app/data/cache.db
